# Database (local Supabase defaults)
DB_HOST=127.0.0.1
DB_PORT=54322
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres

# Supabase Storage / admin key
# Local CLI commands accept either SUPABASE_SECRET_KEY or SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SECRET_KEY=<set-secret-key-or-local-admin-key>
# SUPABASE_SERVICE_ROLE_KEY=<same-value-as-supabase-secret-key>

# Optional YouTube proxy (torproxy HTTP port)
# Example: http://127.0.0.1:8118
KCONTEXT_YOUTUBE_PROXY_URL=

# Optional provider-aware proxy config. Leave generic unless using Decodo.
KCONTEXT_YOUTUBE_PROXY_PROVIDER=generic

# Optional Decodo residential rotating endpoint
DECODO_PROXY_SCHEME=http
DECODO_PROXY_HOST=
DECODO_PROXY_PORT=
DECODO_PROXY_USERNAME=
DECODO_PROXY_PASSWORD=

# Optional Decodo Web Scraping API backend
# Store only the token payload after "Basic ".
DECODO_SCRAPER_API_URL=https://scraper-api.decodo.com/v2/scrape
DECODO_SCRAPER_API_BASIC_TOKEN=

# Optional torproxy published host ports for docker-compose.proxy.yml
KCONTEXT_TORPROXY_HTTP_PORT=8118
KCONTEXT_TORPROXY_SOCKS_PORT=9050
