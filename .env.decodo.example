# Decodo residential proxy configuration for YouTube fetch/list.
# Copy to .env.decodo and fill the values from the Decodo dashboard.

KCONTEXT_YOUTUBE_PROXY_PROVIDER=decodo

# Rotating residential endpoint
DECODO_PROXY_SCHEME=http
DECODO_PROXY_HOST=
DECODO_PROXY_PORT=
DECODO_PROXY_USERNAME=
DECODO_PROXY_PASSWORD=

# Optional smoke-check canary
DECODO_CANARY_VIDEO_ID=DucXv5xjhW4

# Optional Decodo Web Scraping API backend
# Store only the token payload after "Basic ".
DECODO_SCRAPER_API_URL=https://scraper-api.decodo.com/v2/scrape
DECODO_SCRAPER_API_BASIC_TOKEN=
# Recommended for Korean manual subtitle backlog when `youtube_subtitles` returns 613.
DECODO_SCRAPER_API_GEO=Korea
